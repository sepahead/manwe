# ============================================================================
#  manwe — training/research ground for crebain
#  .gitignore: keep source, configs, docs, and tiny fixtures; drop everything
#  that is generated, downloaded, heavy, or machine-specific.
# ============================================================================

# ----------------------------------------------------------------------------
#  Datasets, model weights & ML artifacts  (never commit — see docs/MODEL_CONTRACTS.md)
# ----------------------------------------------------------------------------
# Datasets and downloaded/prepared data
/data/**
/datasets/**
!/data/**/
!/datasets/**/
# Keep dataset manifests.
!/data/**/data.yaml
!/data/**/dataset.yaml
!/datasets/**/data.yaml
!/datasets/**/dataset.yaml
!**/data.yaml
!**/dataset.yaml
# Keep DVC pointers if used.
!**/*.dvc

# Model weights / checkpoints / exports (weights are supplied, never shipped)
*.pt
*.pth
*.ckpt
*.weights
*.onnx
*.safetensors
*.gguf
*.bin
*.tflite
*.pb
# TensorRT artifacts.
*.engine
*.plan
*.trt
*.mlmodel
*.mlmodelc/
*.mlpackage/
*.coreml
# Cached tensors/features are regenerable.
*.npz
weights/
checkpoints/
exported_models/
model_zoo/
# Darknet-style configs are regenerable; YAML configs remain tracked.
*.cfg

# Experiment tracking, logs & run outputs
runs/
outputs/
# Hydra output.
multirun/
lightning_logs/
wandb/
mlruns/
.aim/
.neptune/
tensorboard/
tb_logs/
events.out.tfevents.*
*.log

# ----------------------------------------------------------------------------
#  Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments & package managers
.env
.env.*
!.env.example
*.env
.envrc
.netrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
# Machine-local defaults remain ignored; the package default is reproducible.
.python-version
!python/.python-version

# Local credentials and private keys
*.pem
*.p12
*.pfx
*.key
credentials*.json
credential*.json
secret*.yaml
secret*.yml
secrets*.yaml
secrets*.yml
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.jks
*.keystore
kubeconfig
kubeconfig.*
*kubeconfig*.yaml
*kubeconfig*.yml

# Testing / typing / linting caches
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache
.pytest_cache/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
mutants.out/
nosetests.xml
*.cover

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# ----------------------------------------------------------------------------
#  Rust  (inference / benchmark crates)
# ----------------------------------------------------------------------------
debug/
target/
**/*.rs.bk
*.pdb

# ----------------------------------------------------------------------------
#  Node  (metal-yolo-tests tooling, plotting helpers)
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------------------------------------------------------------------
#  Media  (benchmark videos & captures are regenerated, never committed)
# ----------------------------------------------------------------------------
*.mp4
*.mov
*.avi
*.mkv
*.webm
# Raw audio captures are generated; synthetic smoke audio is created at test time.
*.wav
*.flac
*.gif
# Keep documentation images.
!docs/**/*.gif
!docs/**/*.png

# ----------------------------------------------------------------------------
#  OS / editor cruft
# ----------------------------------------------------------------------------
.DS_Store
._*
.localized
# Local review-tool state can contain internal security findings.
.superstack/
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*.swo
*~
